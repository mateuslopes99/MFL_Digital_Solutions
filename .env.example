# ============================================================
# MFL Digital Solutions — Variáveis de Ambiente
# Copie este arquivo para .env e preencha com suas chaves
# ============================================================

# --- SERVIDOR ---
FLASK_ENV=development
FLASK_PORT=5000
SECRET_KEY=mude-esta-chave-para-algo-seguro

# --- OPENAI ---
OPENAI_API_KEY=sk-...

# --- TWILIO (WhatsApp) ---
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# --- BANCO DE DADOS ---
DATABASE_URL=sqlite:///data/mfl_digital.db

# --- NOTIFICAÇÕES (email dos corretores) ---
# Separados por vírgula
CORRETOR_A_WHATSAPP=whatsapp:+5582...
CORRETOR_B_WHATSAPP=whatsapp:+5582...

# --- CRM (opcional) ---
PIPEDRIVE_API_TOKEN=
PIPEDRIVE_DOMAIN=

# --- CONFIGURAÇÕES DO BOT ---
BOT_NAME=Assistente MFL
COMPANY_NAME=MFL Digital Solutions
RESPONSE_TIMEOUT_SECONDS=30
