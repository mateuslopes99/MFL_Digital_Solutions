# ══════════════════════════════════════════════════════════════════
# MFL Digital Solutions — Variáveis de Ambiente (.env.example)
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commit o .env no git!
# ══════════════════════════════════════════════════════════════════

# ── Flask ──────────────────────────────────────────────────────────
FLASK_ENV=development          # development | production
FLASK_PORT=5000
SECRET_KEY=GERE_COM_python_-c_"import_secrets;print(secrets.token_urlsafe(32))"

# ── Admin credentials ──────────────────────────────────────────────
ADMIN_USER=admin
ADMIN_PASS=TROQUE_ESTA_SENHA_ANTES_DE_PRODUCAO

# ── Twilio (WhatsApp) ──────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886   # sandbox ou número comprado
TWILIO_FROM_NUMBER=whatsapp:+14155238886       # mesmo número (remetente dos alertas)

# ── Alertas Admin (WhatsApp pessoal do dono da MFL) ────────────────
MFL_ADMIN_WHATSAPP=whatsapp:+5582999999999     # SEU número para receber alertas

# ── Corretores (notificação de lead HOT/WARM) ──────────────────────
CORRETOR_A_WHATSAPP=whatsapp:+5582999999999
CORRETOR_B_WHATSAPP=whatsapp:+5582888888888

# ── E-mail (relatórios automáticos para clientes) ──────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu_email@gmail.com
SMTP_PASS=sua_senha_de_app_google   # Senha de App (não senha normal do Gmail)
MFL_EMAIL_FROM=MFL Digital Solutions <seu_email@gmail.com>

# ── IA (OpenAI) ────────────────────────────────────────────────────
USE_MOCK=true                  # true = regras locais | false = GPT real
OPENAI_API_KEY=sk-...

# ── Servidor de produção ───────────────────────────────────────────
SERVER_THREADS=4               # Waitress threads (produção)
