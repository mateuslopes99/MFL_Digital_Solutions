{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "buildCommand": "pip install -r backend/requirements.txt && cd frontend/app && npm install && npm run build"
  },
  "deploy": {
    "startCommand": "cd backend && waitress-serve --port=$PORT --threads=4 --call app:create_app",
    "healthcheckPath": "/health",
    "healthcheckTimeout": 30,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
